{"jsonrpc":"2.0","id":41,"method":"tools/call","params":{"name":"elementor-mcp-update-widget","arguments":{"post_id":10016,"element_id":"7b9fa4e5","settings":{"html":"\u003c!--\n  TiffinGrab — \"Are we in your area?\" section (paste into Elementor HTML widget).\n  Home stack band 1 (after hero): peach strip #fdeae2 — reads clearly darker than hero #fff8f6; alternates with #fff8f6 sections.\n  Elementor hosts match this band to avoid white seams.\n  Requires: wordpress/tiffingrab-delivery-ajax-config.php (or equivalent) so window.tiffinGrabDelivery.nonce exists.\n  Brand green: Elementor Site Settings → Global Colors → \"WhatsApp Green\" (--e-global-color-whatsapp).\n--\u003e\n\u003c!-- Fonts loaded once in home-2026-hero-tags.html (template 9825). --\u003e\n\u003csection class=\"tg-sa\" id=\"tg-service-area\" aria-labelledby=\"tg-sa-title\"\u003e\n  \u003cstyle\u003e\n    /* Pinch-zoom / iOS visual viewport: reinforce root clip + canvas (in case hero-tags widget order differs). */\n    @media (max-width: 767px) {\n      html:has(body.elementor-page-10016),\n      body.elementor-page-10016 {\n        background-color: #fff8f6 !important;\n      }\n      html:has(body.elementor-page-10016) {\n        overflow-x: hidden;\n        width: 100%;\n        max-width: 100%;\n      }\n      body.elementor-page-10016 {\n        overflow-x: hidden;\n        width: 100%;\n        max-width: 100%;\n        position: relative;\n        overscroll-behavior-x: none;\n      }\n    }\n    /* Full-bleed + kill Elementor default white behind the band so sections meet cleanly */\n    .elementor-widget-html:has(#tg-service-area),\n    .elementor-widget-html:has(#tg-service-area) .elementor-widget-container,\n    .elementor-widget-html-custom:has(#tg-service-area),\n    .elementor-widget-html-custom:has(#tg-service-area) .elementor-widget-container,\n    .elementor-widget-wrap:has(#tg-service-area),\n    .elementor-column:has(#tg-service-area),\n    .elementor-column-wrap:has(#tg-service-area),\n    .elementor-section:has(#tg-service-area),\n    .e-con:has(#tg-service-area),\n    .e-con-inner:has(#tg-service-area) {\n      overflow: visible !important;\n      max-width: none !important;\n      background-color: #fdeae2 !important;\n      background-image: none !important;\n    }\n    /* Full-bleed band: breaks out of Elementor’s boxed column so peach meets the hero edge-to-edge */\n    .tg-sa {\n      --tg-brand-green: var(--e-global-color-whatsapp, #25d366);\n      --tg-on-surface: #231a15;\n      --tg-on-variant: #564339;\n      --tg-surface-low: #fdeae2;\n      --tg-surface-lowest: #ffffff;\n      --tg-orange: #f06b1a;\n      --tg-orange-mid: #e37b3e;\n      --tg-orange-deep: #c55a10;\n      --tg-secondary: var(--tg-brand-green);\n      --tg-page: #fff8f6;\n      font-family: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n      color: var(--tg-on-surface);\n      background: var(--tg-surface-low);\n      width: 100vw;\n      max-width: none;\n      margin-left: calc(50% - 50vw);\n      margin-right: calc(50% - 50vw);\n      margin-top: 0;\n      border-radius: 0;\n      padding: clamp(2.75rem, 5vw, 4.5rem) clamp(1.25rem, 4vw, 2rem)\n        clamp(3rem, 6vw, 5rem);\n      position: relative;\n      z-index: 1;\n      /* Soft top edge + lift so the band separates from hero (#fff8f6) without a hard rule */\n      box-shadow: inset 0 1px 0 rgba(137, 114, 104, 0.12);\n      overflow-x: clip;\n    }\n    @supports (width: 100dvw) {\n      .tg-sa {\n        width: 100dvw;\n        margin-left: calc(50% - 50dvw);\n        margin-right: calc(50% - 50dvw);\n      }\n    }\n    .tg-sa * { box-sizing: border-box; }\n    .tg-sa .screen-reader-text {\n      position: absolute;\n      width: 1px;\n      height: 1px;\n      padding: 0;\n      margin: -1px;\n      overflow: hidden;\n      clip: rect(0, 0, 0, 0);\n      white-space: nowrap;\n      border: 0;\n    }\n    .tg-sa-inner {\n      max-width: 1180px;\n      margin: 0 auto;\n      text-align: center;\n    }\n    .tg-sa-head {\n      margin-bottom: 0;\n    }\n    .tg-sa-badge {\n      display: inline-block;\n      padding: 0.35rem 1rem;\n      border-radius: 999px;\n      font-size: 0.68rem;\n      font-weight: 700;\n      letter-spacing: 0.14em;\n      text-transform: uppercase;\n      color: var(--tg-orange);\n      background: rgba(240, 107, 26, 0.07);\n      outline: 1px solid rgba(240, 107, 26, 0.28);\n      margin: 0 0 1.1rem;\n    }\n    .tg-sa h2#tg-sa-title {\n      font-family: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n      font-weight: 800;\n      letter-spacing: -0.02em;\n      font-size: clamp(2rem, 4.5vw, 3.15rem);\n      line-height: 1.12;\n      margin: 0 0 1rem;\n      color: var(--tg-on-surface);\n      min-height: 2.35em;\n    }\n    .tg-sa-lede {\n      margin: 0 auto 2.25rem;\n      max-width: 42rem;\n      font-size: 1.05rem;\n      line-height: 1.65;\n      color: var(--tg-on-variant);\n      font-weight: 400;\n    }\n    .tg-sa-bar {\n      display: flex;\n      align-items: stretch;\n      flex-wrap: nowrap;\n      gap: 0;\n      max-width: 36rem;\n      margin: 0 auto 3rem;\n      padding: 0.35rem;\n      background: var(--tg-surface-lowest);\n      border-radius: 999px;\n      box-shadow: 0 24px 40px rgba(35, 26, 21, 0.07);\n      outline: 1px solid rgba(220, 193, 181, 0.15);\n      transition: box-shadow 0.2s ease, outline-color 0.2s ease;\n      overflow: visible !important;\n    }\n    .tg-sa-bar:focus-within {\n      outline-color: rgba(240, 107, 26, 0.28);\n      box-shadow: 0 28px 48px rgba(240, 107, 26, 0.12);\n    }\n    .tg-sa-bar svg.pin {\n      flex: 0 0 auto;\n      width: 1.35rem;\n      height: 1.35rem;\n      margin: auto 0.35rem auto 1rem;\n      color: rgba(240, 107, 26, 0.72);\n    }\n    .tg-sa-input-wrap {\n      flex: 1 1 auto;\n      min-width: 0;\n      position: relative;\n      display: flex;\n      align-items: stretch;\n      overflow: visible !important;\n    }\n    #tg-service-area .tg-sa-bar input[type=\"text\"] {\n      width: 100%;\n      min-width: 0;\n      border: 0;\n      background: transparent !important;\n      padding: 0.85rem 0.5rem;\n      font-size: 0.95rem;\n      font-weight: 500;\n      color: #231a15 !important;\n      -webkit-text-fill-color: #231a15 !important;\n      outline: none;\n      text-transform: uppercase;\n    }\n    #tg-service-area .tg-sa-bar input[type=\"text\"]:-webkit-autofill,\n    #tg-service-area .tg-sa-bar input[type=\"text\"]:-webkit-autofill:hover,\n    #tg-service-area .tg-sa-bar input[type=\"text\"]:-webkit-autofill:focus {\n      -webkit-box-shadow: 0 0 0 40px #ffffff inset !important;\n      box-shadow: 0 0 0 40px #ffffff inset !important;\n      -webkit-text-fill-color: #231a15 !important;\n    }\n    .tg-sa-suggest {\n      position: absolute;\n      left: 0;\n      right: 0;\n      top: calc(100% + 6px);\n      max-height: min(50vh, 280px);\n      overflow-y: scroll;\n      overflow-x: hidden;\n      margin: 0;\n      padding: 6px;\n      list-style: none;\n      background: var(--tg-surface-lowest);\n      border-radius: 1rem;\n      box-shadow: 0 20px 44px rgba(35, 26, 21, 0.14);\n      outline: 1px solid rgba(220, 193, 181, 0.22);\n      z-index: 50;\n      text-align: left;\n      -webkit-overflow-scrolling: touch;\n      overscroll-behavior: contain;\n      touch-action: pan-y;\n      scrollbar-gutter: stable;\n    }\n    .tg-sa-suggest[hidden] {\n      display: none !important;\n    }\n    .tg-sa-suggest li {\n      margin: 0;\n      padding: 10px 12px;\n      border-radius: 0.65rem;\n      cursor: pointer;\n      font-size: 0.88rem;\n      line-height: 1.25;\n      color: var(--tg-on-surface);\n    }\n    .tg-sa-suggest li[aria-selected=\"true\"],\n    .tg-sa-suggest li:hover {\n      background: rgba(240, 107, 26, 0.1);\n    }\n    .tg-sa-suggest li .tg-sa-code {\n      font-weight: 700;\n      font-family: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n      color: var(--tg-orange);\n      letter-spacing: 0.04em;\n    }\n    .tg-sa-suggest li .tg-sa-hint {\n      display: block;\n      margin-top: 3px;\n      font-size: 0.72rem;\n      font-weight: 500;\n      color: var(--tg-on-variant);\n      opacity: 0.88;\n      letter-spacing: 0.02em;\n    }\n    #tg-service-area .tg-sa-bar input::placeholder {\n      color: rgba(137, 114, 104, 0.65);\n      -webkit-text-fill-color: rgba(137, 114, 104, 0.65);\n      text-transform: none;\n    }\n    /* Scoped + explicit colors so Elementor/theme button rules (e.g. white hover text) don’t break contrast */\n    #tg-service-area .tg-sa-bar button {\n      flex: 0 0 auto;\n      border: 0;\n      cursor: pointer;\n      font-family: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n      font-weight: 500;\n      font-size: 0.95rem;\n      letter-spacing: 0.02em;\n      text-transform: none;\n      color: #ffffff !important;\n      padding: 0.85rem 1.35rem;\n      border-radius: 999px;\n      background-color: #f06b1a !important;\n      white-space: nowrap;\n      min-height: 48px;\n      box-shadow: 0 8px 20px rgba(10, 10, 10, 0.12);\n      transition: transform 0.22s ease, box-shadow 0.22s ease, background-color 0.22s ease, color 0.22s ease;\n      will-change: transform;\n      -webkit-tap-highlight-color: transparent;\n    }\n    #tg-service-area .tg-sa-bar button:hover:not(:disabled) {\n      transform: translateY(-2px) scale(1.02);\n      background-color: #e85f0f !important;\n      color: #ffffff !important;\n      box-shadow: 0 14px 28px rgba(240, 107, 26, 0.34);\n    }\n    #tg-service-area .tg-sa-bar button:active:not(:disabled) {\n      transform: translateY(0) scale(0.99);\n      background-color: #d9560c !important;\n      color: #ffffff !important;\n    }\n    #tg-service-area .tg-sa-bar button:disabled {\n      opacity: 1 !important;\n      cursor: wait;\n      transform: none;\n      box-shadow: 0 4px 14px rgba(180, 75, 25, 0.22);\n      background-color: #a8460f !important;\n      color: #ffffff !important;\n    }\n    @media (max-width: 520px) {\n      .tg-sa-bar { flex-wrap: wrap; border-radius: 1.5rem; padding: 0.5rem; }\n      .tg-sa-bar button { width: 100%; margin-top: 0.25rem; }\n    }\n    @media (max-width: 767px) {\n      #tg-service-area .tg-sa-bar button:hover:not(:disabled) {\n        transform: none;\n        background-color: #e85f0f !important;\n        color: #ffffff !important;\n      }\n    }\n    .tg-sa-result {\n      max-width: 36rem;\n      margin: -2rem auto 2.5rem;\n      min-height: 1.25rem;\n      font-size: 0.95rem;\n      font-weight: 500;\n      color: var(--tg-on-variant);\n    }\n    .tg-sa-result.tg-ok {\n      color: var(--tg-on-variant);\n      text-align: left;\n    }\n    .tg-sa-result.tg-ok .tg-sa-slot-title {\n      display: block;\n      font-family: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n      font-weight: 800;\n      color: var(--tg-secondary);\n      margin-bottom: 0.35rem;\n      text-align: center;\n    }\n    .tg-sa-result.tg-ok .tg-sa-slot-area {\n      display: block;\n      text-align: center;\n      font-size: 0.9rem;\n      font-weight: 600;\n      color: var(--tg-on-surface);\n      margin: 0 0 0.65rem;\n      line-height: 1.35;\n    }\n    .tg-sa-result.tg-ok ul.tg-sa-slots {\n      margin: 0.5rem auto 0;\n      padding: 0 0 0 1.15rem;\n      max-width: 28rem;\n      color: var(--tg-on-surface);\n      font-size: 0.95rem;\n      line-height: 1.5;\n    }\n    .tg-sa-result.tg-err { color: #b45309; }\n    .tg-sa-grid {\n      display: grid;\n      grid-template-columns: repeat(2, 1fr);\n      gap: 1rem;\n      text-align: center;\n    }\n    @media (min-width: 640px) { .tg-sa-grid { grid-template-columns: repeat(3, 1fr); } }\n    @media (min-width: 1024px) { .tg-sa-grid { grid-template-columns: repeat(5, 1fr); } }\n    .tg-sa-card {\n      background: var(--tg-surface-lowest);\n      border-radius: 1.25rem;\n      padding: 1.35rem 1rem;\n      box-shadow: 0 18px 36px rgba(35, 26, 21, 0.055);\n      outline: 1px solid rgba(220, 193, 181, 0.12);\n      transition: transform 0.2s ease, box-shadow 0.2s ease;\n    }\n    .tg-sa-card:hover {\n      transform: translateY(-2px);\n      box-shadow: 0 22px 44px rgba(240, 107, 26, 0.1);\n      outline-color: rgba(240, 107, 26, 0.22);\n    }\n    .tg-sa-card strong {\n      display: block;\n      font-family: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n      font-size: 1.05rem;\n      font-weight: 800;\n      color: var(--tg-orange);\n      margin-bottom: 0.35rem;\n    }\n    .tg-sa-card span {\n      display: block;\n      font-size: 0.62rem;\n      font-weight: 600;\n      letter-spacing: 0.14em;\n      text-transform: uppercase;\n      color: rgba(86, 67, 57, 0.55);\n    }\n    @media (max-width: 767px) {\n      /* Compact area list: one pill per city (tap uses data-postal), not full-width cards */\n      .tg-sa-grid {\n        display: flex;\n        flex-wrap: wrap;\n        justify-content: center;\n        align-items: center;\n        gap: 0.45rem;\n        max-width: 100%;\n      }\n      .tg-sa-card {\n        flex: 0 1 auto;\n        width: auto;\n        max-width: 100%;\n        margin: 0;\n        padding: 0.42rem 0.95rem;\n        border-radius: 999px;\n        display: inline-flex;\n        align-items: center;\n        justify-content: center;\n        text-align: center;\n        cursor: pointer;\n        -webkit-tap-highlight-color: transparent;\n        box-shadow: 0 4px 14px rgba(35, 26, 21, 0.06);\n        transition: transform 0.15s ease, box-shadow 0.2s ease, outline-color 0.2s ease;\n      }\n      .tg-sa-card:active {\n        transform: scale(0.98);\n      }\n      .tg-sa-card strong {\n        margin: 0;\n        font-size: 0.78rem;\n        font-weight: 800;\n        display: inline;\n        line-height: 1.2;\n      }\n      .tg-sa-card span,\n      .tg-sa-card .tg-sa-card-pins {\n        display: none !important;\n      }\n    }\n    .tg-sa-card-pins {\n      margin-top: 0.75rem;\n      display: flex;\n      flex-wrap: wrap;\n      gap: 0.4rem;\n      justify-content: center;\n      align-items: center;\n    }\n    #tg-service-area .tg-sa-pin-pill {\n      appearance: none;\n      -webkit-appearance: none;\n      border: 1px solid rgba(240, 107, 26, 0.35);\n      cursor: pointer;\n      font-family: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n      font-size: 0.72rem;\n      font-weight: 800;\n      letter-spacing: 0.05em;\n      color: #a34a0d !important;\n      background-color: #fff5ef !important;\n      padding: 0.42rem 0.75rem;\n      border-radius: 999px;\n      outline: none;\n      box-shadow: none;\n      transition: background-color 0.2s ease, color 0.2s ease, transform 0.18s ease, border-color 0.2s ease, box-shadow 0.2s ease;\n      -webkit-tap-highlight-color: transparent;\n    }\n    #tg-service-area .tg-sa-pin-pill:hover {\n      color: #ffffff !important;\n      background-color: #f06b1a !important;\n      border-color: #f06b1a;\n      box-shadow: 0 6px 18px rgba(240, 107, 26, 0.28);\n    }\n    #tg-service-area .tg-sa-pin-pill:active {\n      transform: scale(0.96);\n      color: #ffffff !important;\n      background-color: #c25312 !important;\n      border-color: #c25312;\n    }\n    #tg-service-area .tg-sa-pin-pill:focus {\n      outline: none;\n    }\n    #tg-service-area .tg-sa-pin-pill:focus-visible {\n      outline: 2px solid #f06b1a;\n      outline-offset: 3px;\n    }\n    .tg-sa-foot {\n      margin-top: 2.75rem;\n      display: flex;\n      align-items: flex-start;\n      justify-content: center;\n      gap: 0.5rem;\n      color: var(--tg-on-variant);\n      font-size: 0.9rem;\n      font-weight: 500;\n      max-width: 34rem;\n      margin-left: auto;\n      margin-right: auto;\n      line-height: 1.5;\n    }\n    .tg-sa-foot svg {\n      flex-shrink: 0;\n      width: 1.25rem;\n      height: 1.25rem;\n      margin-top: 0.1rem;\n    }\n    .tg-sa-foot a {\n      color: var(--tg-orange);\n      font-weight: 700;\n      text-decoration: underline;\n      text-underline-offset: 3px;\n    }\n    .tg-sa-foot a:hover {\n      color: var(--tg-orange-deep);\n    }\n    @media (max-width: 767px) {\n      .tg-sa {\n        padding-left: max(1rem, env(safe-area-inset-left, 0px));\n        padding-right: max(1rem, env(safe-area-inset-right, 0px));\n        -webkit-text-size-adjust: 100%;\n      }\n      .tg-sa h2#tg-sa-title {\n        font-size: clamp(1.6rem, 7vw, 2.35rem);\n        hyphens: auto;\n      }\n      .tg-sa-lede {\n        font-size: 1rem;\n        margin-bottom: 1.75rem;\n      }\n      #tg-service-area .tg-sa-bar input[type=\"text\"] {\n        font-size: 16px;\n      }\n      .tg-sa-suggest li {\n        min-height: 44px;\n        box-sizing: border-box;\n      }\n      .tg-sa-grid {\n        /* flex pill layout from block above when ≤767px */\n        gap: 0.45rem;\n      }\n      #tg-service-area .tg-sa-bar button {\n        min-height: 48px;\n      }\n    }\n    @media (max-width: 480px) {\n      .tg-sa-pin-pill {\n        min-height: 44px;\n        padding: 0.5rem 0.85rem;\n      }\n    }\n  \u003c/style\u003e\n  \u003cdiv class=\"tg-sa-inner\"\u003e\n    \u003cheader class=\"tg-sa-head\"\u003e\n      \u003cspan class=\"tg-sa-badge\"\u003eDelivery coverage\u003c/span\u003e\n      \u003ch2 id=\"tg-sa-title\"\u003eAre we in your area?\u003c/h2\u003e\n    \u003c/header\u003e\n    \u003cp class=\"tg-sa-lede\"\u003e\n      We currently serve residents and offices across the Greater Toronto Area. Enter your postal code to see if\n      TiffinGrab is cooking in your neighborhood today.\n    \u003c/p\u003e\n    \u003cform class=\"tg-sa-bar\" id=\"tg-sa-form\" novalidate\u003e\n      \u003csvg class=\"pin\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" aria-hidden=\"true\"\u003e\n        \u003cpath d=\"M12 21s7-4.35 7-10a7 7 0 1 0-14 0c0 5.65 7 10 7 10z\" /\u003e\n        \u003ccircle cx=\"12\" cy=\"11\" r=\"2.5\" fill=\"currentColor\" stroke=\"none\" /\u003e\n      \u003c/svg\u003e\n      \u003clabel class=\"screen-reader-text\" for=\"tg-sa-input\"\u003ePostal code\u003c/label\u003e\n      \u003cdiv class=\"tg-sa-input-wrap\"\u003e\n        \u003cinput\n          id=\"tg-sa-input\"\n          name=\"postal-code\"\n          type=\"text\"\n          inputmode=\"text\"\n          autocomplete=\"postal-code\"\n          autocapitalize=\"characters\"\n          spellcheck=\"false\"\n          aria-autocomplete=\"list\"\n          aria-controls=\"tg-sa-suggest-list\"\n          aria-expanded=\"false\"\n          placeholder=\"Start typing a postal code (e.g., M5V)\"\n          maxlength=\"8\"\n        /\u003e\n        \u003cul class=\"tg-sa-suggest\" id=\"tg-sa-suggest-list\" role=\"listbox\" aria-label=\"Suggested postal codes\" hidden\u003e\u003c/ul\u003e\n      \u003c/div\u003e\n      \u003cbutton type=\"submit\" id=\"tg-sa-submit\"\u003eCheck Availability\u003c/button\u003e\n    \u003c/form\u003e\n    \u003cdiv class=\"tg-sa-result\" id=\"tg-sa-result\" role=\"status\" aria-live=\"polite\"\u003e\u003c/div\u003e\n    \u003cdiv class=\"tg-sa-grid\" id=\"tg-sa-area-grid\" aria-label=\"Areas we serve\"\u003e\n      \u003cdiv class=\"tg-sa-card\" data-postal=\"M5V 1J2\" role=\"button\" tabindex=\"0\"\u003e\n        \u003cstrong\u003eToronto\u003c/strong\u003e\u003cspan\u003eDowntown Core\u003c/span\u003e\n        \u003cdiv class=\"tg-sa-card-pins\"\u003e\n          \u003cbutton type=\"button\" class=\"tg-sa-pin-pill\" data-postal=\"M5V 1J2\" aria-label=\"Check delivery for M5V 1J2, Toronto\"\u003eM5V 1J2\u003c/button\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"tg-sa-card\" data-postal=\"M1B 3B5\" role=\"button\" tabindex=\"0\"\u003e\n        \u003cstrong\u003eScarborough\u003c/strong\u003e\u003cspan\u003eEast GTA\u003c/span\u003e\n        \u003cdiv class=\"tg-sa-card-pins\"\u003e\n          \u003cbutton type=\"button\" class=\"tg-sa-pin-pill\" data-postal=\"M1B 3B5\" aria-label=\"Check delivery for M1B 3B5, Scarborough\"\u003eM1B 3B5\u003c/button\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"tg-sa-card\" data-postal=\"L6Y 4R2\" role=\"button\" tabindex=\"0\"\u003e\n        \u003cstrong\u003eBrampton\u003c/strong\u003e\u003cspan\u003eWest GTA\u003c/span\u003e\n        \u003cdiv class=\"tg-sa-card-pins\"\u003e\n          \u003cbutton type=\"button\" class=\"tg-sa-pin-pill\" data-postal=\"L6Y 4R2\" aria-label=\"Check delivery for L6Y 4R2, Brampton\"\u003eL6Y 4R2\u003c/button\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"tg-sa-card\" data-postal=\"L5B 1M2\" role=\"button\" tabindex=\"0\"\u003e\n        \u003cstrong\u003eMississauga\u003c/strong\u003e\u003cspan\u003eWest GTA\u003c/span\u003e\n        \u003cdiv class=\"tg-sa-card-pins\"\u003e\n          \u003cbutton type=\"button\" class=\"tg-sa-pin-pill\" data-postal=\"L5B 1M2\" aria-label=\"Check delivery for L5B 1M2, Mississauga\"\u003eL5B 1M2\u003c/button\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"tg-sa-card\" data-postal=\"M8V 1A1\" role=\"button\" tabindex=\"0\"\u003e\n        \u003cstrong\u003eEtobicoke\u003c/strong\u003e\u003cspan\u003eWest GTA\u003c/span\u003e\n        \u003cdiv class=\"tg-sa-card-pins\"\u003e\n          \u003cbutton type=\"button\" class=\"tg-sa-pin-pill\" data-postal=\"M8V 1A1\" aria-label=\"Check delivery for M8V 1A1, Etobicoke\"\u003eM8V 1A1\u003c/button\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"tg-sa-card\" data-postal=\"M2N 6K1\" role=\"button\" tabindex=\"0\"\u003e\n        \u003cstrong\u003eNorth York\u003c/strong\u003e\u003cspan\u003eCentral GTA\u003c/span\u003e\n        \u003cdiv class=\"tg-sa-card-pins\"\u003e\n          \u003cbutton type=\"button\" class=\"tg-sa-pin-pill\" data-postal=\"M2N 6K1\" aria-label=\"Check delivery for M2N 6K1, North York\"\u003eM2N 6K1\u003c/button\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"tg-sa-card\" data-postal=\"L3R 0G1\" role=\"button\" tabindex=\"0\"\u003e\n        \u003cstrong\u003eMarkham\u003c/strong\u003e\u003cspan\u003eYork Region\u003c/span\u003e\n        \u003cdiv class=\"tg-sa-card-pins\"\u003e\n          \u003cbutton type=\"button\" class=\"tg-sa-pin-pill\" data-postal=\"L3R 0G1\" aria-label=\"Check delivery for L3R 0G1, Markham\"\u003eL3R 0G1\u003c/button\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"tg-sa-card\" data-postal=\"L4K 4M2\" role=\"button\" tabindex=\"0\"\u003e\n        \u003cstrong\u003eVaughan\u003c/strong\u003e\u003cspan\u003eYork Region\u003c/span\u003e\n        \u003cdiv class=\"tg-sa-card-pins\"\u003e\n          \u003cbutton type=\"button\" class=\"tg-sa-pin-pill\" data-postal=\"L4K 4M2\" aria-label=\"Check delivery for L4K 4M2, Vaughan\"\u003eL4K 4M2\u003c/button\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"tg-sa-card\" data-postal=\"L6K 3R8\" role=\"button\" tabindex=\"0\"\u003e\n        \u003cstrong\u003eOakville\u003c/strong\u003e\u003cspan\u003eHalton Region\u003c/span\u003e\n        \u003cdiv class=\"tg-sa-card-pins\"\u003e\n          \u003cbutton type=\"button\" class=\"tg-sa-pin-pill\" data-postal=\"L6K 3R8\" aria-label=\"Check delivery for L6K 3R8, Oakville\"\u003eL6K 3R8\u003c/button\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"tg-sa-card\" data-postal=\"L6E 1A1\" role=\"button\" tabindex=\"0\"\u003e\n        \u003cstrong\u003eRichmond Hill\u003c/strong\u003e\u003cspan\u003eYork Region\u003c/span\u003e\n        \u003cdiv class=\"tg-sa-card-pins\"\u003e\n          \u003cbutton type=\"button\" class=\"tg-sa-pin-pill\" data-postal=\"L6E 1A1\" aria-label=\"Check delivery for L6E 1A1, Richmond Hill\"\u003eL6E 1A1\u003c/button\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"tg-sa-foot\"\u003e\n      \u003csvg viewBox=\"0 0 24 24\" aria-hidden=\"true\"\u003e\n        \u003ccircle cx=\"12\" cy=\"12\" r=\"10\" fill=\"var(--e-global-color-whatsapp, #25d366)\" /\u003e\n        \u003ctext x=\"12\" y=\"16\" text-anchor=\"middle\" fill=\"#fff\" font-size=\"12\" font-weight=\"700\" font-family=\"Geist,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif\"\u003ei\u003c/text\u003e\n      \u003c/svg\u003e\n      \u003cp\u003e\n        Don’t see your city? We’re expanding rapidly.\n        \u003ca href=\"/contact/\"\u003eJoin the waitlist\u003c/a\u003e.\n      \u003c/p\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cscript\u003e\n    (function () {\n      var form = document.getElementById(\"tg-sa-form\");\n      var input = document.getElementById(\"tg-sa-input\");\n      var btn = document.getElementById(\"tg-sa-submit\");\n      var out = document.getElementById(\"tg-sa-result\");\n      var listEl = document.getElementById(\"tg-sa-suggest-list\");\n      var areaGrid = document.getElementById(\"tg-sa-area-grid\");\n      if (!form || !input || !btn || !out || !listEl) return;\n\n      /* Keep focus on input when interacting with the list (incl. scrollbar) so blur doesn’t close before scroll */\n      listEl.addEventListener(\"mousedown\", function (e) {\n        e.preventDefault();\n      });\n\n      /* Keep wheel scroll inside the dropdown when it has overflow */\n      listEl.addEventListener(\n        \"wheel\",\n        function (e) {\n          if (listEl.hidden) return;\n          var top = listEl.scrollTop;\n          var max = listEl.scrollHeight - listEl.clientHeight;\n          var dy = e.deltaY;\n          if ((dy \u003c 0 \u0026\u0026 top \u003e 0) || (dy \u003e 0 \u0026\u0026 top \u003c max - 0.5)) {\n            e.stopPropagation();\n          }\n        },\n        { passive: true }\n      );\n\n      /** GTA-focused examples; filters as the user types (not every valid code). */\n      var POSTAL_SUGGEST = [\n        [\"M5V 1J2\", \"Toronto — Downtown\"],\n        [\"M5H 2N2\", \"Toronto — Financial District\"],\n        [\"M5G 1M2\", \"Toronto — Hospital Row\"],\n        [\"M4W 1J5\", \"Toronto — Yorkville\"],\n        [\"M4Y 1B4\", \"Toronto — Church–Wellesley\"],\n        [\"M6J 1J6\", \"Toronto — Trinity-Bellwoods\"],\n        [\"M6K 3E9\", \"Toronto — Liberty Village\"],\n        [\"M5A 1A1\", \"Toronto — Distillery / East\"],\n        [\"M4M 2Y8\", \"Toronto — Leslieville\"],\n        [\"M8V 1A1\", \"Etobicoke — Lakeshore\"],\n        [\"M8W 4M5\", \"Etobicoke — Alderwood\"],\n        [\"M8X 1B2\", \"Etobicoke — The Kingsway\"],\n        [\"M9C 1B8\", \"Etobicoke — Central\"],\n        [\"M9B 2K4\", \"Etobicoke — Islington\"],\n        [\"M9W 1J5\", \"Etobicoke — Rexdale\"],\n        [\"M3C 0C1\", \"North York — Don Mills\"],\n        [\"M2J 1V8\", \"North York — Fairview\"],\n        [\"M2N 6K1\", \"North York — Yonge \u0026 Sheppard\"],\n        [\"M6A 2T9\", \"North York — Lawrence\"],\n        [\"M2R 2N1\", \"North York — Bayview Village\"],\n        [\"M1P 2W3\", \"Scarborough — Agincourt\"],\n        [\"M1V 2T4\", \"Scarborough — Milliken\"],\n        [\"M1B 3B5\", \"Scarborough — Malvern\"],\n        [\"M1K 2R1\", \"Scarborough — Kennedy\"],\n        [\"M1N 2T7\", \"Scarborough — Cliffside\"],\n        [\"L4T 1A1\", \"Mississauga — Airport\"],\n        [\"L5B 1M2\", \"Mississauga — Square One\"],\n        [\"L5A 3K2\", \"Mississauga — Cooksville\"],\n        [\"L5V 2N6\", \"Mississauga — Erin Mills\"],\n        [\"L5N 7Y9\", \"Mississauga — Meadowvale\"],\n        [\"L4W 2M8\", \"Mississauga — Dixie\"],\n        [\"L6Y 4R2\", \"Brampton — Downtown\"],\n        [\"L6X 1A8\", \"Brampton — West\"],\n        [\"L6T 4M8\", \"Brampton — East\"],\n        [\"L6Z 3Y9\", \"Brampton — North\"],\n        [\"L6R 3K5\", \"Brampton — Sandalwood\"],\n        [\"L3R 0G1\", \"Markham — Downtown\"],\n        [\"L3T 7T6\", \"Markham — Thornhill\"],\n        [\"L6C 0C9\", \"Markham — Cornell\"],\n        [\"L6B 1A8\", \"Markham — Berczy\"],\n        [\"L4J 8X9\", \"Vaughan — Thornhill\"],\n        [\"L4K 4M2\", \"Vaughan — Concord\"],\n        [\"L6A 4K3\", \"Vaughan — Maple\"],\n        [\"L4H 0G6\", \"Vaughan — Woodbridge\"],\n        [\"L6E 1A1\", \"Richmond Hill — Langstaff\"],\n        [\"L4C 9M7\", \"Richmond Hill — Oak Ridges\"],\n        [\"L4B 4M8\", \"Richmond Hill — Hillcrest\"],\n        [\"L6G 1A3\", \"Markham — Unionville\"],\n        [\"L6H 6P5\", \"Oakville — Uptown\"],\n        [\"L6L 5M1\", \"Oakville — Bronte\"],\n        [\"L6M 3J3\", \"Oakville — River Oaks\"],\n        [\"L6K 3R8\", \"Oakville — Downtown\"],\n        [\"M7A 1A1\", \"Toronto — Queen’s Park\"],\n        [\"M5J 2T9\", \"Toronto — Waterfront\"],\n        [\"M5B 1S2\", \"Toronto — Ryerson / Dundas\"],\n        [\"M4T 1W5\", \"Toronto — Summerhill\"],\n        [\"M4S 1B6\", \"Toronto — Davisville\"],\n        [\"M6G 1M6\", \"Toronto — Christie Pits\"],\n        [\"M6H 1K5\", \"Toronto — Dufferin Grove\"],\n        [\"M6P 1A6\", \"Toronto — High Park\"],\n        [\"M6S 4K6\", \"Toronto — Bloor West\"],\n        [\"M8Z 3B9\", \"Etobicoke — Mimico\"],\n        [\"L5M 6J3\", \"Mississauga — Streetsville\"],\n        [\"L5J 2M4\", \"Mississauga — Lakeview\"],\n        [\"L4Z 2H6\", \"Mississauga — City Centre\"],\n        [\"L6W 3W8\", \"Brampton — Bramalea\"],\n        [\"L3S 4R7\", \"Markham — South\"],\n        [\"L4E 4K1\", \"Richmond Hill — North\"],\n        [\"L4G 6H4\", \"Aurora — Central\"],\n        [\"L1S 7K9\", \"Ajax — Central\"],\n        [\"L1J 2K5\", \"Pickering — Town Centre\"],\n        [\"L1H 7K4\", \"Oshawa — Downtown\"],\n        [\"M9V 1B6\", \"Etobicoke — Humberwood\"],\n        [\"M9L 2X6\", \"North York — Steeles West\"],\n        [\"M9M 2W6\", \"North York — Weston\"],\n      ];\n\n      var suggestTimer = null;\n      var activeIdx = -1;\n      var filtered = [];\n\n      function compact(s) {\n        return String(s || \"\")\n          .toUpperCase()\n          .replace(/[^A-Z0-9]/g, \"\");\n      }\n\n      function areaNameFromApiPayload(d) {\n        if (!d || typeof d !== \"object\") return \"\";\n        var keys = [\"area_name\", \"areaName\", \"area\", \"location\", \"zone\", \"region\", \"city_area\", \"neighborhood\"];\n        for (var k = 0; k \u003c keys.length; k++) {\n          var v = d[keys[k]];\n          if (typeof v === \"string\" \u0026\u0026 v.trim()) return v.trim();\n        }\n        return \"\";\n      }\n\n      /** Match full postal or FSA to GTA hint list for a human-readable area label. */\n      function areaNameFromPostal(norm) {\n        var n = compact(norm);\n        if (n.length \u003c 6) return \"\";\n        var i;\n        for (i = 0; i \u003c POSTAL_SUGGEST.length; i++) {\n          if (compact(POSTAL_SUGGEST[i][0]) === n) return POSTAL_SUGGEST[i][1];\n        }\n        var fsa = n.slice(0, 3);\n        for (i = 0; i \u003c POSTAL_SUGGEST.length; i++) {\n          if (compact(POSTAL_SUGGEST[i][0]).slice(0, 3) === fsa) return POSTAL_SUGGEST[i][1];\n        }\n        return \"\";\n      }\n\n      function formatSlotListItem(line) {\n        if (line != null \u0026\u0026 typeof line === \"object\") {\n          var time =\n            line.time ||\n            line.slot ||\n            line.label ||\n            line.text ||\n            line.title ||\n            line.name ||\n            \"\";\n          var ar =\n            (typeof line.area === \"string\" \u0026\u0026 line.area.trim()) ||\n            (typeof line.area_name === \"string\" \u0026\u0026 line.area_name.trim()) ||\n            (typeof line.areaName === \"string\" \u0026\u0026 line.areaName.trim()) ||\n            \"\";\n          if (time \u0026\u0026 ar) return String(time) + \" — \" + String(ar);\n          if (time) return String(time);\n          try {\n            return JSON.stringify(line);\n          } catch (e) {\n            return \"\";\n          }\n        }\n        return String(line);\n      }\n\n      function setListOpen(open) {\n        listEl.hidden = !open;\n        input.setAttribute(\"aria-expanded\", open ? \"true\" : \"false\");\n        if (!open) {\n          activeIdx = -1;\n          listEl.innerHTML = \"\";\n          filtered = [];\n        }\n      }\n\n      function renderSuggestions(items) {\n        listEl.innerHTML = \"\";\n        filtered = items.slice(0, 40);\n        activeIdx = filtered.length ? 0 : -1;\n        listEl.scrollTop = 0;\n        filtered.forEach(function (row, i) {\n          var code = row[0];\n          var hint = row[1];\n          var li = document.createElement(\"li\");\n          li.setAttribute(\"role\", \"option\");\n          li.setAttribute(\"id\", \"tg-sa-opt-\" + i);\n          li.setAttribute(\"aria-selected\", \"false\");\n          var c = document.createElement(\"span\");\n          c.className = \"tg-sa-code\";\n          c.textContent = code;\n          li.appendChild(c);\n          var h = document.createElement(\"span\");\n          h.className = \"tg-sa-hint\";\n          h.textContent = hint;\n          li.appendChild(h);\n          li.addEventListener(\"mousedown\", function (e) {\n            e.preventDefault();\n            pickSuggestion(code);\n          });\n          listEl.appendChild(li);\n        });\n        listEl.hidden = filtered.length === 0;\n        input.setAttribute(\"aria-expanded\", filtered.length ? \"true\" : \"false\");\n        highlightActive();\n      }\n\n      function pickSuggestion(code) {\n        var n = compact(code);\n        input.value = n.length === 6 ? n.slice(0, 3) + \" \" + n.slice(3) : code;\n        setListOpen(false);\n        input.focus();\n      }\n\n      function filterSuggestions() {\n        var q = compact(input.value);\n        if (q.length \u003c 1 || q.length \u003e= 6) {\n          setListOpen(false);\n          return;\n        }\n        var scored = [];\n        for (var i = 0; i \u003c POSTAL_SUGGEST.length; i++) {\n          var code = POSTAL_SUGGEST[i][0];\n          var hint = POSTAL_SUGGEST[i][1];\n          var c = compact(code);\n          var fsa = c.slice(0, 3);\n          if (c.indexOf(q) === 0) {\n            scored.push({ row: [code, hint], rank: 0 });\n          } else if (q.length \u003c= 3 \u0026\u0026 fsa.indexOf(q) === 0) {\n            scored.push({ row: [code, hint], rank: 1 });\n          }\n        }\n        scored.sort(function (a, b) {\n          if (a.rank !== b.rank) return a.rank - b.rank;\n          return compact(a.row[0]).localeCompare(compact(b.row[0]));\n        });\n        var rows = scored.map(function (s) {\n          return s.row;\n        });\n        if (!rows.length) {\n          setListOpen(false);\n          return;\n        }\n        renderSuggestions(rows);\n      }\n\n      function scheduleFilter() {\n        clearTimeout(suggestTimer);\n        suggestTimer = setTimeout(filterSuggestions, 100);\n      }\n\n      /** Scroll only the dropdown (not the page) so keyboard selection stays visible. */\n      function scrollActiveOptionIntoView(li) {\n        if (!li || listEl.hidden) return;\n        var pad = 6;\n        var lr = listEl.getBoundingClientRect();\n        var ir = li.getBoundingClientRect();\n        if (ir.top \u003c lr.top + pad) {\n          listEl.scrollTop -= lr.top + pad - ir.top;\n        } else if (ir.bottom \u003e lr.bottom - pad) {\n          listEl.scrollTop += ir.bottom - (lr.bottom - pad);\n        }\n      }\n\n      function highlightActive() {\n        var lis = listEl.querySelectorAll(\"li\");\n        for (var i = 0; i \u003c lis.length; i++) {\n          lis[i].setAttribute(\"aria-selected\", i === activeIdx ? \"true\" : \"false\");\n        }\n        if (activeIdx \u003e= 0 \u0026\u0026 lis[activeIdx]) {\n          scrollActiveOptionIntoView(lis[activeIdx]);\n        }\n      }\n\n      input.addEventListener(\"input\", function () {\n        scheduleFilter();\n      });\n\n      input.addEventListener(\"focus\", function () {\n        if (compact(input.value).length \u003e= 1 \u0026\u0026 compact(input.value).length \u003c 6) {\n          scheduleFilter();\n        }\n      });\n\n      input.addEventListener(\"blur\", function () {\n        setTimeout(function () {\n          setListOpen(false);\n        }, 180);\n      });\n\n      input.addEventListener(\"keydown\", function (e) {\n        if (listEl.hidden || !filtered.length) {\n          if (e.key === \"Escape\") setListOpen(false);\n          return;\n        }\n        if (e.key === \"ArrowDown\") {\n          e.preventDefault();\n          if (activeIdx \u003c filtered.length - 1) {\n            activeIdx++;\n            highlightActive();\n          } else {\n            var maxScroll = listEl.scrollHeight - listEl.clientHeight;\n            var step = Math.min(56, Math.max(32, Math.floor(listEl.clientHeight * 0.22)));\n            listEl.scrollTop = Math.min(maxScroll, listEl.scrollTop + step);\n          }\n        } else if (e.key === \"ArrowUp\") {\n          e.preventDefault();\n          if (activeIdx \u003e 0) {\n            activeIdx--;\n            highlightActive();\n          } else {\n            var step = Math.min(56, Math.max(32, Math.floor(listEl.clientHeight * 0.22)));\n            listEl.scrollTop = Math.max(0, listEl.scrollTop - step);\n          }\n        } else if (e.key === \"Enter\" \u0026\u0026 activeIdx \u003e= 0) {\n          e.preventDefault();\n          pickSuggestion(filtered[activeIdx][0]);\n        } else if (e.key === \"Escape\") {\n          setListOpen(false);\n        }\n      });\n\n      /** Theme exposes `deliverySlots` (hello-elementor-child-v2 delivery-slots-frontend). */\n      function ajaxConfig() {\n        var custom = window.tiffinGrabDelivery || {};\n        var theme = window.deliverySlots || {};\n        return {\n          ajaxUrl: custom.ajaxUrl || theme.ajaxUrl || \"/wp-admin/admin-ajax.php\",\n          nonce: custom.nonce || theme.nonce || \"\",\n        };\n      }\n\n      function normalizePin(raw) {\n        return String(raw || \"\")\n          .toUpperCase()\n          .replace(/[^A-Z0-9]/g, \"\")\n          .slice(0, 6);\n      }\n\n      function formatDisplayFromNormalized(n) {\n        if (n.length \u003c= 3) return n;\n        return n.slice(0, 3) + \" \" + n.slice(3);\n      }\n\n      function parseResponseText(t) {\n        try {\n          return JSON.parse(t);\n        } catch (e) {\n          return t;\n        }\n      }\n\n      function runDeliveryCheckFromInput() {\n        setListOpen(false);\n        out.textContent = \"\";\n        out.className = \"tg-sa-result\";\n\n        var norm = normalizePin(input.value);\n        if (norm.length \u003c 6) {\n          out.classList.add(\"tg-err\");\n          out.textContent = \"Please enter a valid Canadian postal code.\";\n          return;\n        }\n        input.value = formatDisplayFromNormalized(norm);\n\n        var c = ajaxConfig();\n        var ajaxUrl = c.ajaxUrl;\n        var nonce = c.nonce;\n        if (!nonce) {\n          out.classList.add(\"tg-err\");\n          out.textContent =\n            \"Delivery check needs a security nonce. Add wordpress/tiffingrab-delivery-ajax-config.php to your child theme, or ensure the theme’s delivery script loads on this page.\";\n          return;\n        }\n\n        btn.disabled = true;\n        out.textContent = \"Checking…\";\n\n        var body = new URLSearchParams();\n        body.set(\"action\", \"check_delivery_slot\");\n        body.set(\"nonce\", nonce);\n        body.set(\"pincode\", formatDisplayFromNormalized(norm).replace(/\\s+/g, \"+\"));\n\n        fetch(ajaxUrl, {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/x-www-form-urlencoded; charset=UTF-8\",\n            \"X-Requested-With\": \"XMLHttpRequest\",\n          },\n          body: body.toString(),\n          credentials: \"same-origin\",\n        })\n          .then(function (r) {\n            return r.text();\n          })\n          .then(function (text) {\n            var data = parseResponseText(text);\n            if (data \u0026\u0026 typeof data === \"object\" \u0026\u0026 typeof data.success === \"boolean\") {\n              if (data.success === false \u0026\u0026 data.data) {\n                out.classList.add(\"tg-err\");\n                out.textContent =\n                  typeof data.data === \"string\" ? data.data : data.data.message || \"We couldn’t verify that postal code.\";\n                return;\n              }\n              if (data.success === true \u0026\u0026 data.data) {\n                out.classList.add(\"tg-ok\");\n                if (data.data.slots \u0026\u0026 Array.isArray(data.data.slots) \u0026\u0026 data.data.slots.length) {\n                  out.replaceChildren();\n                  var st = document.createElement(\"span\");\n                  st.className = \"tg-sa-slot-title\";\n                  st.textContent = \"Delivery timings\";\n                  out.appendChild(st);\n                  var areaLine =\n                    areaNameFromApiPayload(data.data) || areaNameFromPostal(norm);\n                  if (areaLine) {\n                    var sn = document.createElement(\"span\");\n                    sn.className = \"tg-sa-slot-area\";\n                    sn.textContent = areaLine;\n                    out.appendChild(sn);\n                  }\n                  var ul = document.createElement(\"ul\");\n                  ul.className = \"tg-sa-slots\";\n                  data.data.slots.forEach(function (line) {\n                    var li = document.createElement(\"li\");\n                    li.textContent = formatSlotListItem(line);\n                    ul.appendChild(li);\n                  });\n                  out.appendChild(ul);\n                  return;\n                }\n                out.textContent =\n                  typeof data.data === \"string\" ? data.data : data.data.message || \"You’re in our delivery area.\";\n                return;\n              }\n            }\n            if (typeof data === \"string\" \u0026\u0026 data.trim()) {\n              var el = document.createElement(\"div\");\n              el.innerHTML = data;\n              var t = el.textContent || el.innerText || data;\n              out.classList.add(t.length \u003c 400 ? \"tg-ok\" : \"tg-sa-result\");\n              out.textContent = t.replace(/\\s+/g, \" \").trim().slice(0, 800);\n              return;\n            }\n            out.classList.add(\"tg-err\");\n            out.textContent = \"Something went wrong. Please try again or contact us.\";\n          })\n          .catch(function () {\n            out.classList.add(\"tg-err\");\n            out.textContent = \"Network error. Check your connection and try again.\";\n          })\n          .finally(function () {\n            btn.disabled = false;\n          });\n      }\n\n      form.addEventListener(\"submit\", function (e) {\n        e.preventDefault();\n        runDeliveryCheckFromInput();\n      });\n\n      if (areaGrid) {\n        function activateAreaFromEvent(e) {\n          var pill = e.target \u0026\u0026 e.target.closest ? e.target.closest(\".tg-sa-pin-pill\") : null;\n          var card = e.target \u0026\u0026 e.target.closest ? e.target.closest(\".tg-sa-card[data-postal]\") : null;\n          var el = pill || card;\n          if (!el || !areaGrid.contains(el)) return;\n          var postal = el.getAttribute(\"data-postal\");\n          if (!postal) return;\n          e.preventDefault();\n          input.value = postal;\n          runDeliveryCheckFromInput();\n          try {\n            out.scrollIntoView({ behavior: \"smooth\", block: \"nearest\" });\n          } catch (err) {}\n        }\n        areaGrid.addEventListener(\"click\", activateAreaFromEvent);\n        areaGrid.addEventListener(\"keydown\", function (e) {\n          if (e.key !== \"Enter\" \u0026\u0026 e.key !== \" \") return;\n          var card = e.target \u0026\u0026 e.target.closest ? e.target.closest(\".tg-sa-card[data-postal]\") : null;\n          if (!card || !areaGrid.contains(card)) return;\n          e.preventDefault();\n          activateAreaFromEvent(e);\n        });\n      }\n    })();\n  \u003c/script\u003e\n\u003c/section\u003e\n"}}}}