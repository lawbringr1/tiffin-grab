{"jsonrpc":"2.0","id":41,"method":"tools/call","params":{"name":"elementor-mcp-update-widget","arguments":{"post_id":10016,"element_id":"7d59786","settings":{"html":"\u003c!--\n  TiffinGrab — \"Why Choose Us\" (Elementor HTML widget).\n  Home stack band 2 of 4: light strip #fff8f6 (alternates with peach #fdeae2). #f06b1a accents, Manrope / Work Sans.\n--\u003e\n\u003c!-- Fonts loaded once in home-2026-hero-tags.html (template 9825). --\u003e\n\u003csection class=\"tg-wcu\" id=\"tg-why-choose\" aria-labelledby=\"tg-wcu-title\"\u003e\n  \u003cstyle\u003e\n    .elementor-widget-html:has(#tg-why-choose),\n    .elementor-widget-html:has(#tg-why-choose) .elementor-widget-container,\n    .elementor-widget-html-custom:has(#tg-why-choose),\n    .elementor-widget-html-custom:has(#tg-why-choose) .elementor-widget-container,\n    .elementor-widget-wrap:has(#tg-why-choose),\n    .elementor-column:has(#tg-why-choose),\n    .elementor-column-wrap:has(#tg-why-choose),\n    .elementor-section:has(#tg-why-choose),\n    .e-con:has(#tg-why-choose),\n    .e-con-inner:has(#tg-why-choose) {\n      overflow: visible !important;\n      max-width: none !important;\n      background-color: #fff8f6 !important;\n      background-image: none !important;\n    }\n    .tg-wcu {\n      --wcu-on: #231a15;\n      --wcu-muted: #564339;\n      --wcu-bg: #fff8f6;\n      --wcu-orange: #f06b1a;\n      --wcu-shadow: 0 28px 56px rgba(35, 26, 21, 0.06);\n      font-family: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n      color: var(--wcu-on);\n      background: var(--wcu-bg);\n      width: 100vw;\n      max-width: none;\n      margin-left: calc(50% - 50vw);\n      margin-right: calc(50% - 50vw);\n      margin-top: 0;\n      padding: clamp(3.5rem, 7vw, 6rem) clamp(1.25rem, 4vw, 2rem);\n      box-sizing: border-box;\n      overflow-x: clip;\n    }\n    @supports (width: 100dvw) {\n      .tg-wcu {\n        width: 100dvw;\n        margin-left: calc(50% - 50dvw);\n        margin-right: calc(50% - 50dvw);\n      }\n    }\n    .tg-wcu * {\n      box-sizing: border-box;\n    }\n    .tg-wcu .tg-wcu-icon {\n      font-family: \"Material Symbols Outlined\" !important;\n      font-weight: normal;\n      font-style: normal;\n      letter-spacing: normal;\n      text-transform: none;\n      white-space: nowrap;\n      direction: ltr;\n      -webkit-font-smoothing: antialiased;\n      -moz-osx-font-smoothing: grayscale;\n      font-variation-settings: \"FILL\" 0, \"wght\" 500, \"GRAD\" 0, \"opsz\" 24;\n      font-size: 1.75rem;\n      color: var(--wcu-orange);\n      line-height: 1;\n      display: inline-block;\n    }\n    .tg-wcu-inner {\n      max-width: 1180px;\n      margin: 0 auto;\n    }\n    .tg-wcu-head {\n      text-align: center;\n      margin-bottom: clamp(2.5rem, 5vw, 3.5rem);\n    }\n    .tg-wcu-badge {\n      display: inline-block;\n      padding: 0.35rem 1rem;\n      border-radius: 999px;\n      font-size: 0.68rem;\n      font-weight: 700;\n      letter-spacing: 0.14em;\n      text-transform: uppercase;\n      color: var(--wcu-orange);\n      background: rgba(240, 107, 26, 0.06);\n      outline: 1px solid rgba(240, 107, 26, 0.28);\n      margin-bottom: 1.25rem;\n    }\n    .tg-wcu h2#tg-wcu-title {\n      font-family: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n      font-weight: 800;\n      letter-spacing: -0.02em;\n      line-height: 1.12;\n      font-size: clamp(1.85rem, 4.2vw, 3.1rem);\n      margin: 0 0 1.25rem;\n      color: var(--wcu-on);\n      max-width: 52rem;\n      margin-left: auto;\n      margin-right: auto;\n    }\n    .tg-wcu h2 .tg-wcu-accent {\n      color: var(--wcu-orange);\n      font-style: normal;\n    }\n    .tg-wcu-lede {\n      margin: 0 auto;\n      max-width: 42rem;\n      font-size: 1.05rem;\n      line-height: 1.7;\n      color: var(--wcu-muted);\n      font-weight: 400;\n    }\n    .tg-wcu-grid {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: clamp(2.25rem, 5vw, 4rem);\n    }\n    @media (min-width: 1024px) {\n      .tg-wcu-grid {\n        flex-direction: row;\n        align-items: center;\n        gap: clamp(2.5rem, 4vw, 4.5rem);\n      }\n      .tg-wcu-col-media,\n      .tg-wcu-col-features {\n        flex: 1 1 0;\n        min-width: 0;\n        width: 100%;\n      }\n    }\n    .tg-wcu-figure {\n      margin: 0;\n      border-radius: 1.5rem;\n      overflow: hidden;\n      aspect-ratio: 4 / 3;\n      box-shadow: var(--wcu-shadow);\n      max-width: 560px;\n      margin-left: auto;\n      margin-right: auto;\n    }\n    @media (min-width: 1024px) {\n      .tg-wcu-figure {\n        margin-left: 0;\n        margin-right: 0;\n        max-width: none;\n      }\n    }\n    .tg-wcu-figure img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      display: block;\n    }\n    .tg-wcu-features {\n      list-style: none;\n      margin: 0;\n      padding: 0;\n      display: flex;\n      flex-direction: column;\n      gap: clamp(1.75rem, 3vw, 2.25rem);\n      width: 100%;\n      max-width: 34rem;\n    }\n    @media (min-width: 1024px) {\n      .tg-wcu-features {\n        max-width: none;\n      }\n    }\n    .tg-wcu-features li {\n      display: flex;\n      gap: 1rem;\n      align-items: flex-start;\n    }\n    .tg-wcu-features .tg-wcu-ico {\n      flex-shrink: 0;\n      width: 2.5rem;\n      height: 2.5rem;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n    .tg-wcu-features h3 {\n      font-family: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n      font-size: 1.1rem;\n      font-weight: 700;\n      margin: 0 0 0.35rem;\n      color: var(--wcu-on);\n    }\n    .tg-wcu-features p {\n      margin: 0;\n      font-size: 0.98rem;\n      line-height: 1.65;\n      color: var(--wcu-muted);\n      font-weight: 400;\n    }\n    .tg-wcu-cta-wrap {\n      display: flex;\n      justify-content: center;\n      margin-top: clamp(2.5rem, 5vw, 3.5rem);\n    }\n    /* Same pill as hero “Order Now” (container a2cdc57 primary): white disc + flying arrow */\n    #tg-why-choose a.tg-wcu-cta,\n    #tg-why-choose a.tg-wcu-cta:link,\n    #tg-why-choose a.tg-wcu-cta:visited {\n      position: relative;\n      overflow: hidden;\n      display: inline-flex;\n      align-items: center;\n      justify-content: flex-start;\n      width: fit-content;\n      max-width: min(100%, 42rem);\n      min-height: 44px;\n      height: auto;\n      padding: 6px 48px 6px 22px;\n      border-radius: 999px;\n      background: #f06b1a !important;\n      background-color: #f06b1a !important;\n      color: #ffffff !important;\n      -webkit-text-fill-color: #ffffff;\n      font-family: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n      font-weight: 600;\n      font-size: 0.95rem;\n      letter-spacing: 0.02em;\n      line-height: 1.25;\n      text-decoration: none !important;\n      border: none;\n      box-shadow: none !important;\n      cursor: pointer;\n      box-sizing: border-box;\n      transition: padding 0.5s ease;\n      -webkit-tap-highlight-color: transparent;\n    }\n    #tg-why-choose a.tg-wcu-cta:hover,\n    #tg-why-choose a.tg-wcu-cta:focus-visible {\n      padding: 6px 22px 6px 48px;\n      color: #ffffff !important;\n      -webkit-text-fill-color: #ffffff;\n    }\n    #tg-why-choose a.tg-wcu-cta .tg-wcu-cta-label {\n      position: relative;\n      z-index: 2;\n      padding: 0;\n      margin: 0;\n      color: inherit;\n      white-space: nowrap;\n    }\n    #tg-why-choose a.tg-wcu-cta .tg-wcu-cta-knob {\n      position: absolute;\n      top: 50%;\n      right: 4px;\n      left: auto;\n      width: 32px;\n      height: 32px;\n      min-width: 32px;\n      max-width: 32px;\n      min-height: 32px;\n      max-height: 32px;\n      margin: 0;\n      padding: 0;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      line-height: 0;\n      border-radius: 999px;\n      background: #ffffff;\n      transform: translateY(-50%) rotate(0deg);\n      transition: right 0.5s ease, transform 0.5s ease;\n      z-index: 1;\n      overflow: hidden;\n      pointer-events: none;\n    }\n    #tg-why-choose a.tg-wcu-cta:hover .tg-wcu-cta-knob,\n    #tg-why-choose a.tg-wcu-cta:focus-visible .tg-wcu-cta-knob {\n      right: calc(100% - 36px);\n      transform: translateY(-50%) rotate(45deg);\n    }\n    #tg-why-choose a.tg-wcu-cta .tg-wcu-cta-knob::before {\n      content: \"\";\n      display: block;\n      width: 17px;\n      height: 17px;\n      flex-shrink: 0;\n      background: url(\"data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%23231a15%22%20stroke-width%3D%222.65%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpath%20d%3D%22M7%2017L17%207%22/%3E%3Cpath%20d%3D%22M7%207h10v10%22/%3E%3C/svg%3E\")\n        center center / contain no-repeat;\n    }\n    @media (max-width: 767px) {\n      .tg-wcu {\n        padding-left: max(1rem, env(safe-area-inset-left, 0px));\n        padding-right: max(1rem, env(safe-area-inset-right, 0px));\n        -webkit-text-size-adjust: 100%;\n      }\n      .tg-wcu h2#tg-wcu-title {\n        font-size: clamp(1.55rem, 6.5vw, 2.2rem);\n      }\n      .tg-wcu-lede {\n        font-size: 1rem;\n      }\n      .tg-wcu-figure {\n        border-radius: 1.25rem;\n      }\n      .tg-wcu-cta-wrap {\n        width: 100%;\n        padding: 0 0.25rem;\n        box-sizing: border-box;\n      }\n      /* Knob + padding match hero magnetic pills (home a2cdc57) on mobile */\n      #tg-why-choose a.tg-wcu-cta {\n        display: flex !important;\n        width: 100%;\n        max-width: 22rem;\n        margin-left: auto;\n        margin-right: auto;\n        min-height: 48px;\n        justify-content: flex-start !important;\n        padding: 0.4rem 3.35rem 0.4rem 0.65rem;\n        font-size: clamp(0.8rem, 3.2vw, 0.9rem);\n      }\n      #tg-why-choose a.tg-wcu-cta:hover,\n      #tg-why-choose a.tg-wcu-cta:focus-visible {\n        padding: 0.4rem 0.65rem 0.4rem 3.35rem;\n      }\n      #tg-why-choose a.tg-wcu-cta .tg-wcu-cta-knob {\n        width: 2.35rem;\n        height: 2.35rem;\n        min-width: 2.35rem;\n        max-width: 2.35rem;\n        min-height: 2.35rem;\n        max-height: 2.35rem;\n        right: 0.2rem;\n      }\n      #tg-why-choose a.tg-wcu-cta:hover .tg-wcu-cta-knob,\n      #tg-why-choose a.tg-wcu-cta:focus-visible .tg-wcu-cta-knob {\n        right: calc(100% - 2.55rem);\n      }\n      #tg-why-choose a.tg-wcu-cta .tg-wcu-cta-knob::before {\n        width: 16px;\n        height: 16px;\n        background-position: center center;\n      }\n      .tg-wcu-features h3 {\n        font-size: 1.05rem;\n      }\n      .tg-wcu-features p {\n        font-size: 0.95rem;\n      }\n    }\n    @media (max-width: 380px) {\n      #tg-why-choose a.tg-wcu-cta {\n        padding: 0.4rem 3.2rem 0.4rem 0.5rem;\n      }\n      #tg-why-choose a.tg-wcu-cta:hover,\n      #tg-why-choose a.tg-wcu-cta:focus-visible {\n        padding: 0.4rem 0.5rem 0.4rem 3.2rem;\n      }\n    }\n  \u003c/style\u003e\n  \u003cdiv class=\"tg-wcu-inner\"\u003e\n    \u003cheader class=\"tg-wcu-head\"\u003e\n      \u003cspan class=\"tg-wcu-badge\"\u003eOur Promise\u003c/span\u003e\n      \u003ch2 id=\"tg-wcu-title\"\u003e\n        Why Choose Our Tiffin Service In \u003cspan class=\"tg-wcu-accent\"\u003eToronto And Scarborough\u003c/span\u003e?\n      \u003c/h2\u003e\n      \u003cp class=\"tg-wcu-lede\"\u003e\n        Indulge your tastes and fuel your day with authentic Indian dishes. Our blend of home-style recipes,\n        fresh ingredients, and strict sanitation brings you real comfort with zero hassle.\n      \u003c/p\u003e\n    \u003c/header\u003e\n    \u003cdiv class=\"tg-wcu-grid\"\u003e\n      \u003cdiv class=\"tg-wcu-col-media\"\u003e\n        \u003cfigure class=