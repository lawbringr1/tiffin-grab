{"jsonrpc":"2.0","id":41,"method":"tools/call","params":{"name":"elementor-mcp-update-widget","arguments":{"post_id":9825,"element_id":"4fd2df8","settings":{"html":"\u003c!--\n  TiffinGrab — Home 2026 hero top tags (Elementor HTML widget on template \"Home 2026 Hero\", id 4fd2df8).\n  Boxes the hero section: max-width + horizontal margin auto + padding (no max-width:none on .e-con — that was breaking inset).\n  Social proof row only (no “Freshly cooked daily” pill).\n--\u003e\n\u003clink rel=\"preconnect\" href=\"https://fonts.googleapis.com\" /\u003e\n\u003clink rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin /\u003e\n\u003c!-- Single Google Fonts import for Home 2026 (Geist everywhere). --\u003e\n\u003clink href=\"https://fonts.googleapis.com/css2?family=Geist:wght@100..900\u0026display=swap\" rel=\"stylesheet\" /\u003e\n\u003clink href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1\u0026display=swap\" rel=\"stylesheet\" /\u003e\n\u003cstyle\u003e\n:root {\n  --tg-hero-gutter: clamp(1.5rem, 6vw, 3.5rem);\n  --tg-hero-max: 1320px;\n  --tg-font: \"Geist\", system-ui, -apple-system, \"Segoe UI\", Roboto, Arial, sans-serif;\n}\n/* Pinch-zoom on iOS: classic vw is wider than the *visual* viewport, so gaps show as white. Clip X + page canvas + dvw caps below. */\nbody.elementor-page-10016 {\n  --tg-page-canvas: #fff8f6;\n}\n\n/* Force Geist across the whole Home 2026 page (Elementor kit/theme overrides included). */\nbody.elementor-page-10016,\nbody.elementor-page-10016 button,\nbody.elementor-page-10016 input,\nbody.elementor-page-10016 select,\nbody.elementor-page-10016 textarea,\nbody.elementor-page-10016 .elementor,\nbody.elementor-page-10016 .elementor-widget,\nbody.elementor-page-10016 .e-con,\nbody.elementor-page-10016 .e-con-inner,\nbody.elementor-page-10016 .elementor-heading-title {\n  font-family: var(--tg-font) !important;\n}\n@media (max-width: 767px) {\n  html:has(body.elementor-page-10016),\n  body.elementor-page-10016 {\n    background-color: var(--tg-page-canvas) !important;\n  }\n  html:has(body.elementor-page-10016) {\n    overflow-x: hidden;\n    width: 100%;\n    max-width: 100%;\n  }\n  body.elementor-page-10016 {\n    overflow-x: hidden;\n    width: 100%;\n    max-width: 100%;\n    position: relative;\n    overscroll-behavior-x: none;\n  }\n}\n.elementor-widget-html:has(#tg-hero-tags),\n.elementor-widget-html-custom:has(#tg-hero-tags),\n.elementor-widget-wrap:has(#tg-hero-tags),\n.elementor-column:has(#tg-hero-tags),\n.elementor-column-wrap:has(#tg-hero-tags) {\n  overflow: visible !important;\n  background-color: #fff8f6 !important;\n}\n.elementor-widget-html:has(#tg-hero-tags) .elementor-widget-container,\n.elementor-widget-html-custom:has(#tg-hero-tags) .elementor-widget-container {\n  overflow: visible !important;\n  background-color: #fff8f6 !important;\n  text-align: left !important;\n}\n.elementor-section:has(#tg-hero-tags):not(.elementor-inner-section) {\n  width: 100% !important;\n  max-width: min(var(--tg-hero-max), calc(100vw - 2 * var(--tg-hero-gutter))) !important;\n  margin-left: auto !important;\n  margin-right: auto !important;\n  padding-left: var(--tg-hero-gutter) !important;\n  padding-right: var(--tg-hero-gutter) !important;\n  box-sizing: border-box !important;\n  background-color: #fff8f6 !important;\n}\n.elementor-section:has(#tg-hero-tags):not(.elementor-inner-section) \u003e .e-con.e-parent,\n.elementor-section:has(#tg-hero-tags):not(.elementor-inner-section) \u003e .elementor-container {\n  max-width: 100% !important;\n  margin-left: 0 !important;\n  margin-right: 0 !important;\n}\n.elementor-section:has(#tg-hero-tags) \u003e .elementor-container {\n  box-sizing: border-box !important;\n}\n.elementor:not(:has(\u003e .elementor-section:has(#tg-hero-tags))) \u003e .e-con.e-parent:has(#tg-hero-tags) {\n  width: 100% !important;\n  max-width: min(var(--tg-hero-max), calc(100vw - 2 * var(--tg-hero-gutter))) !important;\n  margin-left: auto !important;\n  margin-right: auto !important;\n  padding-left: var(--tg-hero-gutter) !important;\n  padding-right: var(--tg-hero-gutter) !important;\n  box-sizing: border-box !important;\n  background-color: #fff8f6 !important;\n}\n.tg-hero-tags-align {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n  gap: clamp(0.65rem, 2vw, 1.1rem);\n  max-width: 1180px;\n  margin-left: 0;\n  margin-right: auto;\n  width: 100%;\n  box-sizing: border-box;\n}\n.home-2026-tags {\n  width: 100%;\n}\n.home-2026-social-pill {\n  display: inline-flex;\n  align-items: center;\n  flex-wrap: wrap;\n  max-width: 100%;\n  background: #ffffff;\n  border: 1px solid rgba(35, 26, 21, 0.1);\n  border-radius: 999px;\n  padding: 7px 16px 7px 7px;\n  box-shadow: 0 1px 2px rgba(35, 26, 21, 0.05), 0 6px 20px rgba(35, 26, 21, 0.06);\n  box-sizing: border-box;\n  transition: box-shadow 0.35s ease, border-color 0.35s ease;\n}\n@media (hover: hover) {\n  .home-2026-social-pill:hover {\n    border-color: rgba(240, 107, 26, 0.22);\n    box-shadow: 0 4px 14px rgba(35, 26, 21, 0.08), 0 12px 32px rgba(240, 107, 26, 0.12);\n  }\n}\n.home-2026-social-avatars {\n  display: flex;\n  flex-direction: row;\n  align-items: center;\n  padding: 0 2px 0 1px;\n}\n.home-2026-social-av {\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  border: 2px solid #ffffff;\n  box-sizing: border-box;\n  margin-left: -9px;\n  flex-shrink: 0;\n  position: relative;\n  overflow: hidden;\n  background-color: #e8e4e0;\n  box-shadow: 0 0 0 1px rgba(35, 26, 21, 0.06);\n  transform: translateZ(0);\n  transition: transform 0.4s cubic-bezier(0.34, 1.45, 0.64, 1);\n  transition-delay: 0ms;\n  will-change: transform;\n}\n.home-2026-social-av img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  object-position: center;\n  display: block;\n  pointer-events: none;\n}\n.home-2026-social-av:first-child {\n  margin-left: 0;\n  z-index: 4;\n}\n.home-2026-social-av:nth-child(2) {\n  z-index: 3;\n}\n.home-2026-social-av:nth-child(3) {\n  z-index: 2;\n}\n.home-2026-social-av:nth-child(4) {\n  z-index: 1;\n}\n@media (hover: hover) {\n  .home-2026-social-pill:hover .home-2026-social-av:nth-child(1) {\n    transform: translateY(-6px) scale(1.07);\n    transition-delay: 0ms;\n  }\n  .home-2026-social-pill:hover .home-2026-social-av:nth-child(2) {\n    transform: translateY(-6px) scale(1.07);\n    transition-delay: 55ms;\n  }\n  .home-2026-social-pill:hover .home-2026-social-av:nth-child(3) {\n    transform: translateY(-6px) scale(1.07);\n    transition-delay: 110ms;\n  }\n  .home-2026-social-pill:hover .home-2026-social-av:nth-child(4) {\n    transform: translateY(-6px) scale(1.07);\n    transition-delay: 165ms;\n  }\n  .home-2026-social-av:hover {\n    z-index: 30 !important;\n    transform: translateY(-9px) scale(1.14) !important;\n    transition-delay: 0ms !important;\n    box-shadow: 0 8px 20px rgba(240, 107, 26, 0.25);\n  }\n}\n@media (prefers-reduced-motion: reduce) {\n  .home-2026-social-pill,\n  .home-2026-social-av {\n    transition: none !important;\n  }\n  .home-2026-social-pill:hover .home-2026-social-av,\n  .home-2026-social-av:hover {\n    transform: none !important;\n    box-shadow: 0 0 0 1px rgba(35, 26, 21, 0.06) !important;\n  }\n  .home-2026-social-pill:hover {\n    box-shadow: 0 1px 2px rgba(35, 26, 21, 0.05), 0 6px 20px rgba(35, 26, 21, 0.06) !important;\n    border-color: rgba(35, 26, 21, 0.1) !important;\n  }\n}\n.home-2026-social-text {\n  margin: 0;\n  padding: 0 6px 0 11px;\n  font-family: var(--tg-font);\n  font-size: 16px;\n  line-height: 1.35;\n  font-weight: 500;\n  color: #6b5e56;\n  letter-spacing: 0.01em;\n}\n.home-2026-social-text strong {\n  font-weight: 800;\n  color: #231a15;\n  font-size: 1.08em;\n  letter-spacing: -0.02em;\n}\n@media (max-width: 767px) {\n  :root {\n    --tg-hero-gutter: clamp(1rem, 4.5vw, 1.75rem);\n  }\n  .elementor-section:has(#tg-hero-tags):not(.elementor-inner-section),\n  .elementor:not(:has(\u003e .elementor-section:has(#tg-hero-tags))) \u003e .e-con.e-parent:has(#tg-hero-tags) {\n    padding-left: max(var(--tg-hero-gutter), env(safe-area-inset-left, 0px)) !important;\n    padding-right: max(var(--tg-hero-gutter), env(safe-area-inset-right, 0px)) !important;\n  }\n  .tg-hero-tags-align {\n    max-width: 100%;\n  }\n  .home-2026-social-pill {\n    max-width: 100%;\n    padding: 8px 12px 8px 7px;\n  }\n  .home-2026-social-text {\n    font-size: 14px;\n    line-height: 1.4;\n    padding-left: 9px;\n    word-wrap: break-word;\n  }\n  .home-2026-social-av {\n    width: 30px;\n    height: 30px;\n    margin-left: -8px;\n  }\n  @supports (width: 100dvw) {\n    .elementor-section:has(#tg-hero-tags):not(.elementor-inner-section),\n    .elementor:not(:has(\u003e .elementor-section:has(#tg-hero-tags))) \u003e .e-con.e-parent:has(#tg-hero-tags) {\n      max-width: min(var(--tg-hero-max), calc(100dvw - 2 * var(--tg-hero-gutter))) !important;\n    }\n  }\n}\n\u003c/style\u003e\n\u003cdiv class=\"home-2026-tags\" id=\"tg-hero-tags\"\u003e\n  \u003cdiv class=\"tg-hero-tags-align\"\u003e\n    \u003cdiv class=\"home-2026-social-pill\" role=\"group\" aria-label=\"Social proof\"\u003e\n      \u003cdiv class=\"home-2026-social-avatars\" aria-hidden=\"true\"\u003e\n        \u003cspan class=\"home-2026-social-av\"\u003e\n          \u003cimg\n            src=\"https://cdn.shadcnstudio.com/ss-assets/avatar/avatar-3.png\"\n            alt=\"\"\n            width=\"36\"\n            height=\"36\"\n            loading=\"lazy\"\n            decoding=\"async\"\n          /\u003e\n        \u003c/span\u003e\n        \u003cspan class=\"home-2026-social-av\"\u003e\n          \u003cimg\n            src=\"https://cdn.shadcnstudio.com/ss-assets/avatar/avatar-6.png\"\n            alt=\"\"\n            width=\"36\"\n            height=\"36\"\n            loading=\"lazy\"\n            decoding=\"async\"\n          /\u003e\n        \u003c/span\u003e\n        \u003cspan class=\"home-2026-social-av\"\u