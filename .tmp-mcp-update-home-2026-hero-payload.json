{"jsonrpc":"2.0","id":40,"method":"tools/call","params":{"name":"elementor-mcp-update-widget","arguments":{"post_id":9825,"element_id":"7349cd7","settings":{"html":"\u003c!--\n  TiffinGrab — Hero “Chef’s Special” glass card (Elementor HTML widget, id 7349cd7).\n  Bottom-left, slightly outside the photo; pairs with image frame container 441d39d (36px radius, 12px pad → 24px img).\n--\u003e\n\u003cstyle\u003e\n  /* Column must establish height (image widget); this widget stretches over it like an overlay layer */\n  .elementor-column:has(.home-2026-hero-card),\n  .elementor-column-wrap:has(.home-2026-hero-card) {\n    position: relative !important;\n    overflow: visible !important;\n  }\n  /* Out of flex flow so only the image sizes the frame — avoids extra “band” at bottom */\n  .e-con:has(.home-2026-hero-card) .elementor-widget-html:has(.home-2026-hero-card),\n  .e-con:has(.home-2026-hero-card) .elementor-widget-html-custom:has(.home-2026-hero-card),\n  .elementor-column:has(.home-2026-hero-card) .elementor-widget-html:has(.home-2026-hero-card),\n  .elementor-column:has(.home-2026-hero-card) .elementor-widget-html-custom:has(.home-2026-hero-card) {\n    position: absolute !important;\n    inset: 0 !important;\n    width: 100% !important;\n    height: 100% !important;\n    margin: 0 !important;\n    padding: 0 !important;\n    z-index: 2 !important;\n    pointer-events: none !important;\n  }\n  .elementor-widget-html:has(.home-2026-hero-card) .elementor-widget-container,\n  .elementor-widget-html-custom:has(.home-2026-hero-card) .elementor-widget-container {\n    position: absolute !important;\n    inset: 0 !important;\n    width: 100% !important;\n    height: 100% !important;\n    max-width: none !important;\n    overflow: visible !important;\n    pointer-events: none !important;\n  }\n  .elementor-widget-wrap:has(.home-2026-hero-card) {\n    overflow: visible !important;\n  }\n  /* Concentric rounding: outer frame 36px − 12px padding = 24px on the photo (even white ring on all sides) */\n  .e-con:has(.home-2026-hero-card) .elementor-widget-image,\n  .elementor-column:has(.home-2026-hero-card) .elementor-widget-image {\n    flex: 1 1 auto !important;\n    align-self: stretch !important;\n    min-height: 0 !important;\n    width: 100% !important;\n    margin: 0 !important;\n  }\n  .e-con:has(.home-2026-hero-card) .elementor-widget-image .elementor-widget-container,\n  .e-con:has(.home-2026-hero-card) .elementor-widget-image a.elementor-image,\n  .elementor-column:has(.home-2026-hero-card) .elementor-widget-image .elementor-widget-container,\n  .elementor-column:has(.home-2026-hero-card) .elementor-widget-image a.elementor-image {\n    border-radius: 24px !important;\n    overflow: hidden !important;\n    line-height: 0 !important;\n    margin: 0 !important;\n  }\n  .e-con:has(.home-2026-hero-card) .elementor-widget-image figure,\n  .e-con:has(.home-2026-hero-card) .elementor-widget-image .elementor-image,\n  .elementor-column:has(.home-2026-hero-card) .elementor-widget-image figure,\n  .elementor-column:has(.home-2026-hero-card) .elementor-widget-image .elementor-image {\n    margin: 0 !important;\n    line-height: 0 !important;\n  }\n  .e-con:has(.home-2026-hero-card) .elementor-widget-image img,\n  .e-con:has(.home-2026-hero-card) .elementor-widget-image .elementor-image img,\n  .elementor-column:has(.home-2026-hero-card) .elementor-widget-image img,\n  .elementor-column:has(.home-2026-hero-card) .elementor-widget-image .elementor-image img {\n    border-radius: 24px !important;\n    display: block !important;\n  }\n  .home-2026-hero-card {\n    position: relative;\n    width: 100%;\n    height: 100%;\n    min-height: 100%;\n    pointer-events: none;\n  }\n  .home-2026-hero-blob {\n    position: absolute;\n    opacity: 0.55;\n    z-index: 0;\n    pointer-events: none;\n  }\n  .home-2026-hero-blob.b1 {\n    width: 220px;\n    height: 220px;\n    right: -46px;\n    top: -40px;\n    /* Radial gradient = soft blob look without expensive CSS blur */\n    background: radial-gradient(\n      circle at center,\n      rgba(240, 107, 26, 0.32) 0%,\n      rgba(240, 107, 26, 0.14) 45%,\n      rgba(240, 107, 26, 0) 72%\n    );\n    border-radius: 999px;\n  }\n  .home-2026-hero-blob.b2 {\n    display: none;\n  }\n  .home-2026-hero-float {\n    position: absolute;\n    left: clamp(-22px, -1.8vw, -10px);\n    bottom: clamp(-20px, -1.6vw, -10px);\n    right: auto;\n    width: min(285px, calc(100% - 8px));\n    max-width: 285px;\n    z-index: 3;\n    pointer-events: auto;\n    /* Avoid backdrop-filter blur (causes slow first paint + flicker) */\n    backdrop-filter: none;\n    -webkit-backdrop-filter: none;\n    background: rgba(255, 255, 255, 0.92);\n    border: 1px solid rgba(255, 255, 255, 0.6);\n    border-radius: 20px;\n    box-shadow: 0 14px 35px rgba(20, 20, 20, 0.12);\n    padding: 16px 16px 14px;\n    box-sizing: border-box;\n  }\n  .home-2026-hero-float .hdr {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin-bottom: 8px;\n  }\n  .home-2026-hero-float .ico {\n    width: 34px;\n    height: 34px;\n    border-radius: 999px;\n    background: rgba(255, 219, 202, 0.95);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 15px;\n    flex: 0 0 auto;\n  }\n  .home-2026-hero-float .t {\n    font-weight: 800;\n    font-size: 20px;\n    color: #231a15;\n    line-height: 1.05;\n  }\n  .home-2026-hero-float .d {\n    font-size: 14px;\n    color: #564339;\n    line-height: 1.3;\n    margin: 0 0 10px;\n  }\n  .home-2026-hero-float .btm {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 10px;\n  }\n  .home-2026-hero-float .price {\n    font-weight: 800;\n    color: #f06b1a;\n    font-size: 14px;\n    white-space: nowrap;\n  }\n  .home-2026-hero-float .badge {\n    font-size: 10px;\n    font-weight: 800;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    background: rgba(0, 109, 55, 0.1);\n    color: #006d37;\n    padding: 4px 8px;\n    border-radius: 999px;\n    white-space: nowrap;\n  }\n  @media (max-width: 767px) {\n    .home-2026-hero-float {\n      left: 8px;\n      right: 8px;\n      bottom: 10px;\n      width: auto;\n      max-width: min(100%, calc(100vw - 24px));\n      box-sizing: border-box;\n    }\n    @supports (width: 100dvw) {\n      .home-2026-hero-float {\n        max-width: min(100%, calc(100dvw - 24px));\n      }\n    }\n    .home-2026-hero-float {\n      padding: 12px;\n    }\n    .home-2026-hero-float .btm {\n      flex-wrap: wrap;\n      gap: 8px;\n    }\n    .home-2026-hero-float .t {\n      font-size: 17px;\n    }\n    .home-2026-hero-float .d {\n      font-size: 13px;\n    }\n  }\n\u003c/style\u003e\n\u003cdiv class=\"home-2026-hero-card\"\u003e\n  \u003cdiv class=\"home-2026-hero-blob b1\" aria-hidden=\"true\"\u003e\u003c/div\u003e\n  \u003cdiv class=\"home-2026-hero-float\"\u003e\n    \u003cdiv class=\"hdr\"\u003e\n      \u003cdiv class=\"ico\" aria-hidden=\"true\"\u003e🍽️\u003c/div\u003e\n      \u003cdiv class=\"t\"\u003eChef\u0027s Special\u003c/div\u003e\n    \u003c/div\u003e\n    \u003cp class=\"d\"\u003eMaharaja Thali (Non-veg) - Combination of 7 items\u003c/p\u003e\n    \u003cdiv class=\"btm\"\u003e\n      \u003cdiv class=\"price\"\u003eFrom $15.00 CAD\u003c/div\u003e\n      \u003cdiv class=\"badge\"\u003eHigh Protein\u003c/div\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n"}}}}